    6:  `<div class="frow"><label>Frameworks to go deepest on (optional)</label><input type="text" id="fe" placeholder="e.g., Blue Ocean + JTBD + Porter's Five Forces"></div>`,
    7:  `<div class="frow"><label>Your current positioning instinct (optional)</label><textarea id="fe" rows="2" placeholder="e.g., We want to be the premium artisanal option / We want to own the wellness angle / Not sure — you decide"></textarea></div>`,
    8:  `<div class="fgrid">
          <div class="frow"><label>Current / planned price point</label><input type="text" id="fe" placeholder="${S.brand.isSaaS ? 'e.g., ₹3,000/mo per seat' : S.brand.isD2C ? 'e.g., ₹1,499 per unit' : 'e.g., ₹299 for 1kg pack'}"></div>
          <div class="frow"><label>Target gross margin %</label><input type="text" id="fe2" placeholder="e.g., 40%"></div>
        </div>`,
    9:  `<div class="fgrid">
          <div class="frow"><label>${S.brand.isSaaS ? 'Target ICP: industry / company size' : 'Launch geography priority'}</label><input type="text" id="fe" placeholder="${S.brand.isSaaS ? 'e.g., HR tech buyers at 50-500 person cos in Bangalore' : 'e.g., Delhi NCR first, then Punjab/Haryana'}"></div>
          <div class="frow"><label>90-day budget for GTM</label><input type="text" id="fe2" placeholder="e.g., ₹15 lakh total / ₹3 lakh/month"></div>
        </div>`,
    10: `<div class="frow"><label>Monthly budget to allocate</label><input type="text" id="fe" placeholder="e.g., ₹5 lakh/month — or leave blank for % allocation only"></div>`,
    11: `<div class="frow"><label>Your biggest worry about this business</label><textarea id="fe" rows="2" placeholder="What keeps you up at night? Be specific — the more honest, the more useful the risk analysis."></textarea></div>`,
  };

  return `
    ${stepForms[n] || ''}
    <div style="margin-top:18px;">
      <button class="btn btn-p" id="runBtn" onclick="runGeneric(${n}, gatherExtras(${n}))">Run Step ${n} Analysis →</button>
    </div>`;
}

function gatherExtras(n) {
  const g = (id) => { const el = document.getElementById(id); return el ? el.value.trim() : ''; };
  return {
    extra: g('fe'),
    currentPrice: g('fe'),
    targetMargin: g('fe2'),
    geoFocus: g('fe'),
    budgetNinety: g('fe2') || g('fe'),
    monthlyBudget: g('fe'),
    biggestWorry: g('fe'),
    question: g('fq') || g('fe'),
  };
}

// ── RUNNERS ────────────────────────────────────────────────────────────────────
function runStep1() {
  const brand = v('f1'), stage = v('f2'), bizModel = v('f0biz');
  if (!brand) { toast('Enter brand name', 'err'); return; }
  if (!stage) { toast('Select a brand stage', 'err'); return; }
  if (!bizModel) { toast('Select a business model', 'err'); return; }
  S.brand = {
    brand, stage, bizModel,
    product: v('f3'), location: v('f4'), revenue: v('f5'),
    target: v('f6'), channels: v('f7'), usp: v('f8'),
    budget: v('f9'), notes: v('f10'),
    isB2B: bizModel === 'B2B SaaS' || bizModel === 'Marketplace',
    isD2C: bizModel === 'D2C',
    isFMCG: bizModel === 'FMCG',
    isSaaS: bizModel === 'B2B SaaS',
  };
  S.stage = stage;
  renderSidebar();
  execute(1, buildPrompt(1, {}));
}

function runQ() {
  const q = v('fq');
  if (!q) { toast('Type your question', 'err'); return; }
  execute(12, buildPrompt(12, { question: q }));
}

function runGeneric(n, extras) {
  if (!S.brand.brand && n !== 1) { toast('Complete Step 1 first', 'err'); return; }
  execute(n, buildPrompt(n, extras || {}));
}

function v(id) { const e = document.getElementById(id); return e ? e.value.trim() : ''; }

// ── EXECUTE ────────────────────────────────────────────────────────────────────
async function execute(n, p) {
  if (!S.key) { showWelcome(); setTimeout(() => toast('Enter your OpenRouter key first', 'err'), 300); return; }

  const btn = document.getElementById('runBtn');
  if (btn) { btn.disabled = true; btn.textContent = 'Analyzing...'; }

  const c = document.getElementById('content');
  let loader = document.getElementById('loader');
  if (!loader) {
    loader = document.createElement('div');
    loader.id = 'loader';
    loader.className = 'loading';
    loader.innerHTML = `<div class="spin"></div><div><div class="ltxt">BrandOS is analyzing${S.brand.brand ? ` ${S.brand.brand}` : ''}...</div><div class="lsub">Applying India-specific intelligence</div></div>`;
    c.appendChild(loader);
  }
  c.scrollTop = c.scrollHeight;

  try {
    const out = await callStrategy(p);
    S.resp[n] = { inp: p, out };
    S.done.add(n);
    loader.remove();
    renderSidebar();
    goStep(n);
    setTimeout(() => {
      const rb = document.querySelector('.rbox');
      if (rb) rb.scrollIntoView({behavior:'smooth', block:'start'});
    }, 100);
    toast('Step ' + n + ' complete!', 'ok');
  } catch(err) {
    if (loader) loader.remove();
    if (btn) { btn.disabled = false; btn.textContent = 'Try Again →'; }
    toast('Error: ' + err.message, 'err');
    const errDiv = document.createElement('div');
    errDiv.style.cssText = 'background:rgba(255,77,106,.1);border:1px solid rgba(255,77,106,.3);border-radius:10px;padding:18px;margin-top:16px;font-size:13.5px;color:var(--red);';
    errDiv.innerHTML = `<strong>API Error:</strong> ${escHtml(err.message)}<br><br><span style="color:var(--text2);font-size:12px;">Check your OpenRouter key at openrouter.ai/keys</span>`;
    c.appendChild(errDiv);
  }
}

// ── MARKDOWN RENDERER (fixed) ──────────────────────────────────────────────────
function md(raw) {
  // Escape HTML
  let t = String(raw)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;');

  // Code blocks (preserve)
  const codeBlocks = [];
  t = t.replace(/```[\s\S]*?```/g, m => { codeBlocks.push(m); return `\x00CODE${codeBlocks.length-1}\x00`; });

  // Headers (order matters — longest first)
  t = t.replace(/^#{4}\s+(.+)$/gm, '<h4>$1</h4>');
  t = t.replace(/^#{3}\s+(.+)$/gm, '<h4>$1</h4>');
  t = t.replace(/^#{2}\s+(.+)$/gm, '<h3>$1</h3>');
  t = t.replace(/^#{1}\s+(.+)$/gm, '<h2>$1</h2>');

  // Bold and italic
  t = t.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
  t = t.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  t = t.replace(/\*([^*\n]+?)\*/g, '<em>$1</em>');

  // HR
  t = t.replace(/^[-*_]{3,}$/gm, '<hr>');

  // Blockquotes
  t = t.replace(/^&gt;\s+(.+)$/gm, '<blockquote>$1</blockquote>');

  // Tables — full pass
  t = t.replace(/(?:^[^\n]*\|[^\n]*\n?)+/gm, tableBlock => {
    const rows = tableBlock.trim().split('\n');
    if (rows.length < 2) return tableBlock;
    let html = '<table>';
    rows.forEach((row, i) => {
      // Skip separator rows like |---|---|
      if (/^\|[\s\-:|]+\|/.test(row)) return;
      const cells = row.split('|').slice(1, -1).map(c => c.trim());
      if (cells.length === 0) return;
      const tag = i === 0 ? 'th' : 'td';
      html += '<tr>' + cells.map(c => `<${tag}>${c}</${tag}>`).join('') + '</tr>';
    });
    html += '</table>';
    return html;
  });

  // Unordered lists
  t = t.replace(/((?:^[-*+]\s+.+\n?)+)/gm, block => {
    const items = block.trim().split('\n').map(l => `<li>${l.replace(/^[-*+]\s+/, '')}</li>`).join('');
    return `<ul>${items}</ul>`;
  });

  // Ordered lists
  t = t.replace(/((?:^\d+\.\s+.+\n?)+)/gm, block => {
    const items = block.trim().split('\n').map(l => `<li>${l.replace(/^\d+\.\s+/, '')}</li>`).join('');
    return `<ol>${items}</ol>`;
  });

  // Restore code blocks
  t = t.replace(/\x00CODE(\d+)\x00/g, (_, i) => {
    const code = codeBlocks[parseInt(i)]
      .replace(/^```\w*\n?/, '')
      .replace(/```$/, '');
    return `<pre style="background:var(--surface3);padding:14px;border-radius:8px;overflow-x:auto;font-family:'DM Mono',monospace;font-size:12px;">${code}</pre>`;
  });

  // Paragraphs — wrap double-newline blocks
  t = t.replace(/\n{2,}/g, '</p><p>');
  t = t.replace(/\n/g, '<br>');

  return `<p>${t}</p>`;
}

// ── TOAST ──────────────────────────────────────────────────────────────────────
function toast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => { t.className = 'toast'; }, 3500);
}

// ── INIT ───────────────────────────────────────────────────────────────────────
renderSidebar();
showWelcome();
</script>
