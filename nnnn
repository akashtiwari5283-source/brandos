function renderSidebar() {
  ['tab1','tab2','tab3'].forEach(t => document.getElementById(t)?.classList.remove('active'));
  const tabMap = {strategy:'tab1', execution:'tab2', solver:'tab3'};
  document.getElementById(tabMap[S.mode])?.classList.add('active');

  if (S.mode === 'strategy') {
    document.getElementById('sidebarSteps').innerHTML =
      `<div class="s-section">Layer 1 · Strategy</div>` +
      STEPS.map(s => `
        <div class="si ${S.step===s.id?'active':''} ${S.done.has(s.id)?'done':''}" onclick="goStep(${s.id})">
          <div class="snum">${S.done.has(s.id)?'✓':s.id}</div>
          <div class="slabel">${s.label}</div>
        </div>`).join('');
  } else if (S.mode === 'execution') {
    document.getElementById('sidebarSteps').innerHTML =
      `<div class="s-section">Layer 2 · Execution</div>` +
      EXEC_TOOLS.map(t => `
        <div class="si ${S.execTool===t.id?'active':''}" onclick="selectExecTool('${t.id}')">
          <div class="snum" style="font-size:13px;">${t.icon}</div>
          <div class="slabel">${t.name}</div>
        </div>`).join('');
  } else {
    document.getElementById('sidebarSteps').innerHTML =
      `<div class="s-section">Layer 3 · Problem Solver</div>
       <div class="si active"><div class="snum">🔥</div><div class="slabel">Live Problem Diagnosis</div></div>
       <div style="padding:10px 18px;"><div style="font-size:11px;color:var(--text3);line-height:1.6;">Describe any problem → get diagnosis + 3 actions to run this week</div></div>`;
  }

  const step = STEPS.find(s=>s.id===S.step);
  if (S.mode === 'strategy') {
    document.getElementById('topbarLeft').innerHTML = `Step <b>${S.step||'—'}</b> · <span>${step?step.label:'Welcome'}</span>`;
    document.getElementById('navInfo').textContent = S.step ? `Step ${S.step} of 13` : '— of 13';
    document.getElementById('botnav').style.display = 'flex';
  } else if (S.mode === 'execution') {
    const tool = EXEC_TOOLS.find(t=>t.id===S.execTool);
    document.getElementById('topbarLeft').innerHTML = `<b>⚡ Execution Engine</b> · <span>${tool?tool.name:'Select a tool'}</span>`;
    document.getElementById('botnav').style.display = 'none';
  } else {
    document.getElementById('topbarLeft').innerHTML = `<b>🔥 Problem Solver</b> · <span>Live Diagnosis</span>`;
    document.getElementById('botnav').style.display = 'none';
  }

  const badgeEl = document.getElementById('tBadge');
  if (S.brand.brand) {
    badgeEl.className = 'sbadge on';
    badgeEl.textContent = S.brand.brand + (S.stage ? ` · ${S.stage.split('—')[0].trim()}` : '');
  } else {
    badgeEl.className = 'sbadge';
    badgeEl.textContent = 'No brand set';
  }

  document.getElementById('btnPrev').style.visibility = (S.mode==='strategy' && S.step > 1) ? 'visible' : 'hidden';
  document.getElementById('btnNext').style.visibility = (S.mode==='strategy' && S.step >= 1 && S.step < 13) ? 'visible' : 'hidden';
}

function switchMode(mode) {
  if (!S.key) { toast('Enter your API key first', 'err'); return; }
  S.mode = mode;
  renderSidebar();
  if (mode === 'strategy') {
    if (S.step) goStep(S.step); else showWelcomeContent();
  } else if (mode === 'execution') {
    showExecEngine();
  } else {
    showSolver();
  }
}

function nav(d) {
  const n = S.step + d;
  if (n >= 1 && n <= 13) goStep(n);
  else if (n === 0) showWelcome();
}

