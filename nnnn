  c.appendChild(loader);
  c.scrollTop = c.scrollHeight;
  try {
    const out = await callAI(userPrompt, SYSPROMPT);
    S.resp[`exec_${id}`] = { inp: userPrompt, out };
    loader.remove();
    selectExecTool(id);
    setTimeout(() => {
      const rb = document.querySelector('.rbox');
      if (rb) rb.scrollIntoView({behavior:'smooth', block:'start'});
    }, 100);
    toast(`${tool.name} ready!`, 'ok');
  } catch(err) {
    loader.remove();
    if (btn) { btn.disabled = false; btn.textContent = 'Try Again →'; }
    toast('Error: ' + err.message, 'err');
  }
}

