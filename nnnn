async function sendSolverMessage() {
  const inp = document.getElementById('solverInput');
  if (!inp) return;
  const msg = inp.value.trim();
  if (!msg) { toast('Describe your problem first', 'err'); return; }
  if (!S.key) { toast('Enter API key first', 'err'); return; }
  inp.value = '';

  const b = S.brand;
  const fullMsg = b.brand
    ? `${msg}\n\n${brandContext()}`
    : msg;

  S.solverHistory.push({ role: 'user', content: msg }); // show clean version in UI
  S.solverRunning = true;
  renderSolverChat();
  setTimeout(() => {
    const sa = document.getElementById('solverScrollArea');
    if (sa) sa.scrollTop = sa.scrollHeight;
  }, 50);

  // Build conversation history (all but last)
  const history = S.solverHistory.slice(0, -1);

  try {
    const out = await callAI(fullMsg, SOLVER_SYSTEM, history);
    S.solverHistory.push({ role: 'assistant', content: out });
  } catch(err) {
    S.solverHistory.push({ role: 'assistant', content: `⚠️ Error: ${err.message}` });
  }
  S.solverRunning = false;
  renderSolverChat();
  setTimeout(() => {
    const sa = document.getElementById('solverScrollArea');
    if (sa) sa.scrollTop = sa.scrollHeight;
  }, 100);
}

function escHtml(t) {
  return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
